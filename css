import os
import webbrowser

# Personalize aqui
nome_namorada = "Sua Escolhida" # Coloque o nome dela aqui
seu_nome = "Seu Nome"

html_content = f"""
<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <title>Elite Celebration | 1 Mês</title>
    <link href="https://fonts.googleapis.com" rel="stylesheet">
    <style>
        :root {{
            --gold: linear-gradient(135deg, #c5a059 0%, #fff3a6 50%, #c5a059 100%);
            --gold-solid: #c5a059;
            --black: #050505;
        }}

        body, html {{
            margin: 0; padding: 0; width: 100%; height: 100%;
            background-color: var(--black);
            font-family: 'Montserrat', sans-serif;
            color: white; overflow: hidden;
        }}

        /* --- TELA DE APRESENTAÇÃO --- */
        #intro {{
            position: fixed; top: 0; left: 0; width: 100%; height: 100%;
            background: var(--black);
            display: flex; justify-content: center; align-items: center;
            z-index: 100; transition: opacity 2s ease;
        }}

        .intro-text {{
            font-family: 'Cinzel', serif;
            font-size: 1.5rem;
            color: var(--gold-solid);
            letter-spacing: 8px;
            text-transform: uppercase;
            opacity: 0;
            animation: fadeInOut 4s forwards;
        }}

        @keyframes fadeInOut {{
            20% {{ opacity: 0; transform: translateY(10px); }}
            50% {{ opacity: 1; transform: translateY(0); }}
            80% {{ opacity: 1; }}
            100% {{ opacity: 0; }}
        }}

        /* --- CONTEÚDO PRINCIPAL --- */
        main {{
            opacity: 0;
            display: flex; flex-direction: column; align-items: center;
            justify-content: center; min-height: 100vh;
            transition: opacity 3s ease;
            background: radial-gradient(circle at center, #111 0%, #000 100%);
        }}

        .elite-border {{
            border: 1px solid rgba(197, 160, 89, 0.3);
            padding: 60px; border-radius: 2px;
            text-align: center; position: relative;
            box-shadow: 0 0 50px rgba(0,0,0,1);
        }}

        h1 {{
            font-family: 'Cinzel', serif;
            font-size: 3.5rem; margin: 0;
            background: var(--gold);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            text-shadow: 0 10px 20px rgba(0,0,0,0.5);
        }}

        .counter {{
            color: var(--gold-solid);
            letter-spacing: 4px; font-weight: 200;
            margin-bottom: 40px; text-transform: uppercase;
        }}

        /* --- O BUQUÊ DE LUXO --- */
        .bouquet {{
            position: relative; width: 400px; height: 400px;
            margin: 20px auto;
        }}

        .flower {{ position: absolute; filter: drop-shadow(0 0 15px rgba(197,160,89,0.2)); }}

        /* Rosa Estilizada Black/Gold */
        .rose {{
            width: 80px; height: 80px;
            background: linear-gradient(45deg, #222, #000);
            border: 2px solid #c5a059;
            border-radius: 50% 0 50% 50%;
            transform: rotate(-45deg);
            animation: pulse 3s infinite ease-in-out;
        }}
        
        /* Margarida de Ouro */
        .daisy {{
            width: 70px; height: 70px;
            display: flex; justify-content: center; align-items: center;
        }}
        .petal {{
            position: absolute; width: 10px; height: 35px;
            background: white; border-radius: 20px;
            transform-origin: bottom center;
        }}
        .center {{
            width: 20px; height: 20px; background: var(--gold);
            border-radius: 50%; z-index: 10; box-shadow: 0 0 10px #fff;
        }}

        @keyframes pulse {{
            0%, 100% {{ transform: rotate(-45deg) scale(1); filter: brightness(1); }}
            50% {{ transform: rotate(-45deg) scale(1.05); filter: brightness(1.3); }}
        }}

        /* Posicionamento Estratégico */
        .pos1 {{ top: 0; left: 160px; }}
        .pos2 {{ top: 60px; left: 80px; }}
        .pos3 {{ top: 60px; left: 240px; }}
        .pos4 {{ top: 140px; left: 40px; }}
        .pos5 {{ top: 140px; left: 280px; }}
        .pos6 {{ top: 150px; left: 160px; }}

        .stems {{
            position: absolute; bottom: -20px; left: 195px;
            width: 4px; height: 180px; background: var(--gold-solid);
            opacity: 0.4;
        }}

        /* Partículas de Brilho */
        .sparkle {{
            position: absolute; background: white; border-radius: 50%;
            pointer-events: none; animation: shine 2s infinite;
        }}

        @keyframes shine {{
            0%, 100% {{ opacity: 0; transform: scale(0); }}
            50% {{ opacity: 1; transform: scale(1); }}
        }}
    </style>
</head>
<body>

    <div id="intro">
        <div class="intro-text">O primeiro mês de uma vida inteira...</div>
    </div>

    <main id="main-content">
        <div class="elite-border">
            <div class="counter">30 Dias de Exclusividade</div>
            <h1>{nome_namorada}</h1>
            
            <div class="bouquet">
                <div class="stems"></div>
                <div class="flower rose pos1"></div>
                <div class="flower daisy pos2">
                    <div class="center"></div>
                    <div class="petal" style="transform: rotate(0deg) translateY(-20px)"></div>
                    <div class="petal" style="transform: rotate(60deg) translateY(-20px)"></div>
                    <div class="petal" style="transform: rotate(120deg) translateY(-20px)"></div>
                    <div class="petal" style="transform: rotate(180deg) translateY(-20px)"></div>
                    <div class="petal" style="transform: rotate(240deg) translateY(-20px)"></div>
                    <div class="petal" style="transform: rotate(300deg) translateY(-20px)"></div>
                </div>
                <div class="flower rose pos3"></div>
                <div class="flower daisy pos4">
                    <div class="center"></div>
                    <div class="petal" style="transform: rotate(30deg) translateY(-20px)"></div>
                    <div class="petal" style="transform: rotate(150deg) translateY(-20px)"></div>
                    <div class="petal" style="transform: rotate(270deg) translateY(-20px)"></div>
                </div>
                <div class="flower rose pos5"></div>
                <div class="flower daisy pos6">
                    <div class="center"></div>
                    <div class="petal" style="transform: rotate(0deg) translateY(-20px)"></div>
                    <div class="petal" style="transform: rotate(90deg) translateY(-20px)"></div>
                    <div class="petal" style="transform: rotate(180deg) translateY(-20px)"></div>
                    <div class="petal" style="transform: rotate(270deg) translateY(-20px)"></div>
                </div>
            </div>

            <p style="letter-spacing: 2px; font-weight: 200; margin-top: 50px;">
                Obrigado por cada segundo. <br>
                <span style="color: var(--gold-solid)">Atenciosamente, {seu_nome}</span>
            </p>
        </div>
    </main>

    <script>
        // Lógica da Intro
        setTimeout(() => {{
            document.getElementById('intro').style.opacity = '0';
            setTimeout(() => {{
                document.getElementById('intro').style.display = 'none';
                document.getElementById('main-content').style.opacity = '1';
            }}, 2000);
        }}, 4000);

        // Criar Brilhos (Sparkles)
        function createSparkle() {{
            const s = document.createElement('div');
            s.className = 'sparkle';
            const size = Math.random() * 4 + 'px';
            s.style.width = size; s.style.height = size;
            s.style.top = Math.random() * 100 + 'vh';
            s.style.left = Math.random() * 100 + 'vw';
            document.body.appendChild(s);
            setTimeout(() => s.remove(), 2000);
        }}
        setInterval(createSparkle, 150);
    </script>
</body>
</html>
"""

# Criar arquivo
filename = "celebracao_elite.html"
with open(filename, "w", encoding="utf-8") as f:
    f.write(html_content)

# Abrir no navegador
webbrowser.open(f"file://{{os.path.abspath(filename)}}")
print("Site de Elite com Intro gerado!")
