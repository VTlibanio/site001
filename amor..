<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Nosso Primeiro Mês ❤️</title>
    <style>
        body {
            margin: 0;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background: linear-gradient(135deg, #ff9a9e 0%, #fad0c4 100%);
            color: #4a4a4a;
            display: flex;
            flex-direction: column;
            align-items: center;
            text-align: center;
        }
        .container {
            max-width: 600px;
            margin: 50px 20px;
            background: rgba(255, 255, 255, 0.9);
            padding: 30px;
            border-radius: 20px;
            box-shadow: 0 10px 30px rgba(0,0,0,0.1);
        }
        h1 { color: #ff4d6d; font-size: 2.5em; }
        .heart { color: #ff4d6d; font-size: 50px; animation: pulse 1.5s infinite; }
        @keyframes pulse {
            0% { transform: scale(1); }
            50% { transform: scale(1.2); }
            100% { transform: scale(1); }
        }
        .counter { font-size: 1.2em; font-weight: bold; margin: 20px 0; color: #ff4d6d; }
        .photo-placeholder {
            width: 100%;
            height: 250px;
            background: #eee;
            border-radius: 15px;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 20px 0;
            border: 2px dashed #ff4d6d;
        }
        p { line-height: 1.6; font-size: 1.1em; }
        button {
            background: #ff4d6d;
            color: white;
            border: none;
            padding: 15px 30px;
            border-radius: 25px;
            font-size: 1em;
            cursor: pointer;
            transition: 0.3s;
        }
        button:hover { background: #ff758f; transform: translateY(-3px); }
    </style>
</head>
<body>

    <div class="container">
        <div class="heart">❤️</div>
        <h1>1 Mês de Nós!</h1>
        
        <div class="photo-placeholder">
            <!-- Dica: Substitua o texto abaixo por uma tag <img> com a foto de vocês -->
            <span>Sua foto favorita aqui 📸</span>
        </div>

        <p>Parece que foi ontem que tudo começou, mas em 30 dias você já transformou meu mundo. Feliz nosso primeiro mês!</p>
        
        <div class="counter" id="timer">Contando cada segundo...</div>

        <p><i>"De todos os lugares do mundo, o meu favorito é ao seu lado."</i></p>
        
        <button onclick="surpresa()">Clica aqui, amor!</button>
    </div>

    <script>
        // Função para mostrar um alerta fofo
        function surpresa() {
            alert("Eu te amo daqui até a lua! 🌙✨ Que venham muitos outros meses!");
        }

        // Contador de tempo (ajuste a data abaixo para o dia que começaram)
        const dataInicio = new Date("2024-02-11T00:00:00").getTime(); // FORMATO: ANO-MÊS-DIA

        setInterval(function() {
            const agora = new Date().getTime();
            const distancia = agora - dataInicio;

            const dias = Math.floor(distancia / (1000 * 60 * 60 * 24));
            const horas = Math.floor((distancia % (1000 * 60 * 60 * 24)) / (1000 * 60 * 60));
            const minutos = Math.floor((distancia % (1000 * 60 * 60)) / (1000 * 60));
            const segundos = Math.floor((distancia % (1000 * 60)) / 1000);

            document.getElementById("timer").innerHTML = 
                dias + " dias, " + horas + "h " + minutos + "m " + segundos + "s de puro amor!";
        }, 1000);
    </script>
</body>
</html>
